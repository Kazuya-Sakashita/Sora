generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------
// ユーザー（Supabase Auth と同じ UUID を使用）
// -----------------------------------------------
model User {
  id                   String             @id // Supabase Auth user UUID
  email                String             @unique
  plan                 Plan               @default(FREE)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  onThisDayEnabled     Boolean            @default(true) @map("on_this_day_enabled")
  createdAt            DateTime           @default(now()) @map("created_at")
  pets                 Pet[]
  petMembers           PetMember[]
  pushSubscriptions    PushSubscription[]

  @@map("users")
}

enum Plan {
  FREE
  PLUS
}

// -----------------------------------------------
// ペットプロフィール
// -----------------------------------------------
model Pet {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  nickname    String?
  species     Species?
  breed       String?
  birthDate   DateTime?  @map("birth_date")
  gender      Gender?
  personality String?
  favorites   String?
  photoUrl    String?    @map("photo_url")
  broughtAt   DateTime?  @map("brought_at")
  status      PetStatus  @default(ALIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  memories            Memory[]
  feelings            Feeling[]
  schedules           Schedule[]
  members             PetMember[]
  invites             PetInvite[]
  monthlyLetters      MonthlyLetter[]
  memoryNotifications MemoryNotification[]

  @@map("pets")
}

// -----------------------------------------------
// ペット共同オーナー
// -----------------------------------------------
enum PetRole {
  OWNER
  MEMBER
}

model PetMember {
  id        String   @id @default(uuid())
  petId     String   @map("pet_id")
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      PetRole  @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([petId, userId])
  @@map("pet_members")
}

model PetInvite {
  id        String   @id @default(uuid())
  petId     String   @map("pet_id")
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  token     String   @unique @default(uuid())
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pet_invites")
}

enum PetStatus {
  ALIVE
  RAINBOW_BRIDGE
}

enum Species {
  DOG
  CAT
  RABBIT
  BIRD
  OTHER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

// -----------------------------------------------
// 思い出記録
// -----------------------------------------------
model Memory {
  id          String         @id @default(uuid())
  petId       String         @map("pet_id")
  pet         Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        DateTime
  category    MemoryCategory @default(OTHER)
  moodTag     MoodTag?       @map("mood_tag")
  photoUrls           String[]       @default([]) @map("photo_urls")
  createdAt           DateTime       @default(now()) @map("created_at")
  memoryNotifications MemoryNotification[]

  @@map("memories")
}

enum MemoryCategory {
  TRIP
  DAILY
  HOSPITAL
  TRIMMING
  ANNIVERSARY
  OTHER
}

enum MoodTag {
  HAPPY
  CALM
  WORRIED
  FUN
  LOVING
}

// -----------------------------------------------
// 気持ち記録
// -----------------------------------------------
model Feeling {
  id        String     @id @default(uuid())
  petId     String     @map("pet_id")
  pet       Pet        @relation(fields: [petId], references: [id], onDelete: Cascade)
  tag       FeelingTag
  memo      String?
  date      DateTime
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("feelings")
}

enum FeelingTag {
  HAPPY
  CALM
  FUN
  WORRIED
  LOVING
}

// -----------------------------------------------
// 予定管理
// -----------------------------------------------
model Schedule {
  id        String       @id @default(uuid())
  petId     String       @map("pet_id")
  pet       Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  type      ScheduleType
  title     String
  date      DateTime
  memo      String?
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("schedules")
}

enum ScheduleType {
  HOSPITAL
  TRIMMING
  VACCINE
  ANNIVERSARY
  OTHER
}

// -----------------------------------------------
// あの日のこと通知スケジュール
// -----------------------------------------------
model MemoryNotification {
  id          String                   @id @default(uuid())
  memoryId    String                   @map("memory_id")
  memory      Memory                   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  petId       String                   @map("pet_id")
  pet         Pet                      @relation(fields: [petId], references: [id], onDelete: Cascade)
  scheduledAt DateTime                 @map("scheduled_at")
  type        MemoryNotificationType
  sentAt      DateTime?                @map("sent_at")
  createdAt   DateTime                 @default(now()) @map("created_at")

  @@index([scheduledAt, sentAt])
  @@map("memory_notifications")
}

enum MemoryNotificationType {
  ONE_MONTH
  THREE_MONTHS
  ONE_YEAR
}

// -----------------------------------------------
// 月次AIメモリーレター
// -----------------------------------------------
model MonthlyLetter {
  id          String    @id @default(uuid())
  petId       String    @map("pet_id")
  pet         Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  year        Int
  month       Int
  content     String
  generatedAt DateTime  @default(now()) @map("generated_at")
  notifiedAt  DateTime? @map("notified_at")

  @@unique([petId, year, month])
  @@map("monthly_letters")
}

// -----------------------------------------------
// Web Push 購読情報
// -----------------------------------------------
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}
